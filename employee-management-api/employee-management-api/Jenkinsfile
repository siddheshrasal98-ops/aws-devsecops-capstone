pipeline {
    agent any
    
    tools {
        maven "Maven"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
    steps {
        dir('employee-management-api/employee-management-api') {
            bat 'mvn clean package -DskipTests'
        }
    }
}
    }
}
